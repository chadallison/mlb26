# library(dplyr)
batting_summary = all_pbp |>
# Each row is a pitch, so filter to just the last pitch of each at-bat
filter(last.pitch.of.ab == TRUE) |>
group_by(matchup.batter.fullName) |>
summarise(
# Plate appearances = every at-bat conclusion
PA = n(),
# At bats exclude walks, HBP, sac flies, sac bunts, catcher interference
AB = sum(!(result.event %in% c(
"Walk", "Intent Walk", "Hit By Pitch",
"Sac Fly", "Sac Bunt", "Catcher Interference"
))),
BB  = sum(result.event %in% c("Walk", "Intent Walk")),
HBP = sum(result.event == "Hit By Pitch"),
SO  = sum(result.event == "Strikeout"),
SF  = sum(result.event == "Sac Fly"),
H   = sum(result.event %in% c("Single", "Double", "Triple", "Home Run")),
`1B` = sum(result.event == "Single"),
`2B` = sum(result.event == "Double"),
`3B` = sum(result.event == "Triple"),
HR  = sum(result.event == "Home Run"),
RBI = sum(result.rbi),
# Batting average = H / AB
AVG = round(H / AB, 3),
# On base pct = (H + BB + HBP) / (AB + BB + HBP + SF)
OBP = round((H + BB + HBP) / (AB + BB + HBP + SF), 3),
# Slugging = total bases / AB
SLG = round((`1B` + 2*`2B` + 3*`3B` + 4*HR) / AB, 3),
# OPS = OBP + SLG
OPS = round(OBP + SLG, 3)
) |>
# Avoid divide-by-zero issues for players with 0 AB
mutate(
AVG = if_else(AB == 0, NA_real_, AVG),
SLG = if_else(AB == 0, NA_real_, SLG),
OPS = if_else(AB == 0, NA_real_, OPS)
) |>
arrange(desc(PA))
batting_summary
all_results |>
group_by(team) |>
summarise(scored = sum(score),
allowed = sum(opp_score),
wins = sum(is_win),
losses = sum(1 - is_win),
win_pct = mean(is_win)) |>
mutate(pythag = scored ^ 2 / (scored ^ 2 + allowed ^ 2))
all_results |>
group_by(team) |>
summarise(scored = sum(score),
allowed = sum(opp_score),
wins = sum(is_win),
losses = sum(1 - is_win),
win_pct = mean(is_win)) |>
mutate(pythag = round(scored ^ 2 / (scored ^ 2 + allowed ^ 2), 3))
all_results |>
group_by(team) |>
summarise(scored = sum(score),
allowed = sum(opp_score),
wins = sum(is_win),
losses = sum(1 - is_win),
win_pct = mean(is_win)) |>
mutate(pythag = round(scored ^ 2 / (scored ^ 2 + allowed ^ 2), 3)) |>
arrange(desc(pythag))
all_results |>
group_by(team) |>
summarise(scored = sum(score),
allowed = sum(opp_score),
wins = sum(is_win),
losses = sum(1 - is_win),
win_pct = mean(is_win)) |>
mutate(pythag = (scored ^ 2 / (scored ^ 2 + allowed ^ 2)) * 162)
all_results |>
group_by(team) |>
summarise(scored = sum(score),
allowed = sum(opp_score),
wins = sum(is_win),
losses = sum(1 - is_win),
win_pct = mean(is_win)) |>
mutate(pythag = round((scored ^ 2 / (scored ^ 2 + allowed ^ 2)) * 162, 1))
all_results |>
group_by(team) |>
summarise(scored = sum(score),
allowed = sum(opp_score),
wins = sum(is_win),
losses = sum(1 - is_win),
win_pct = mean(is_win)) |>
mutate(pythag = round((scored ^ 2 / (scored ^ 2 + allowed ^ 2)) * 162, 1)) |>
arrange(desc(pythag))
all_results |>
group_by(team) |>
summarise(scored = sum(score),
allowed = sum(opp_score),
wins = sum(is_win),
losses = sum(1 - is_win),
win_pct = mean(is_win))
knitr::knit_hooks$set(source = function(x, options) {
hook.r = function(x, options) {
fence = "```"
language = tolower(options$engine)
if (language == "node") language = "javascript"
if (!options$highlight) language = "text"
if (!is.null(options$fold_code)) {
paste0("\n\n", "<details><summary>View Code</summary>\n", fence, language,
"\n", x, fence, "\n\n", "</details>\n")
} else paste0('\n\n', fence, language, '\n', x, fence,  '\n\n')
}
x = knitr:::hilight_source(x, "markdown", options)
hook.r(paste(c(x, ""), collapse = "\n"), options)
})
