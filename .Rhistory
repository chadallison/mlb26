team_records
team_records = all_results |>
group_by(team) |>
summarise(gp = n(),
scored = sum(score),
allowed = sum(opp_score),
run_diff = sum(score) - sum(opp_score),
wins = sum(is_win),
losses = sum(1 - is_win),
win_pct = mean(is_win)) |>
mutate(record = paste0(wins, "-", losses)) |>
inner_join(teams_info, by = "team")
team_records
team_records |>
mutate(gtp = 162 - gp)
team_records |>
mutate(gtp = 162 - gp,
py = scored ^ 2 / (scored ^ 2 + allowed ^ 2))
team_records |>
mutate(gtp = 162 - gp,
py = scored ^ 2 / (scored ^ 2 + allowed ^ 2),
proj_wins_remaining = py * gtp)
team_records |>
mutate(gtp = 162 - gp,
py = scored ^ 2 / (scored ^ 2 + allowed ^ 2),
proj_wins_remaining = round(py * gtp, 0))
team_records |>
mutate(gtp = 162 - gp,
py = scored ^ 2 / (scored ^ 2 + allowed ^ 2),
proj_wins_remaining = round(py * gtp, 0),
net_proj_wins = wins + proj_wins_remaining)
team_records |>
mutate(gtp = 162 - gp,
py = scored ^ 2 / (scored ^ 2 + allowed ^ 2),
proj_wins_remaining = round(py * gtp, 0),
net_proj_wins = wins + proj_wins_remaining) |>
arrange(desc(net_proj_wins))
team_records
team_records |>
mutate(rdpg = run_diff / gp) |>
arrange(desc(rdpg))
team_records |>
ggplot(aes(run_diff, win_pct)) +
geom_point()
